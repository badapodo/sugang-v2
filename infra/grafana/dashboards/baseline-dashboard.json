        },
        "tooltip": {
          "mode": "single",
          "sort": "none"
        }
      },
      "targets": [
        {
          "expr": "((sum(rate(http_server_requests_seconds_count{job=\"sugang-v2-baseline\", uri=~\"/api/(baseline|optimistic)/enrollments\", status=~\"2..\"}[1m])) or vector(0)) / sum(rate(http_server_requests_seconds_count{job=\"sugang-v2-baseline\", uri=~\"/api/(baseline|optimistic)/enrollments\"}[1m])))",
          "legendFormat": "2xx ratio"
        },
        {
          "expr": "((sum(rate(http_server_requests_seconds_count{job=\"sugang-v2-baseline\", uri=~\"/api/(baseline|optimistic)/enrollments\", status=~\"4..\"}[1m])) or vector(0)) / sum(rate(http_server_requests_seconds_count{job=\"sugang-v2-baseline\", uri=~\"/api/(baseline|optimistic)/enrollments\"}[1m])))",
          "legendFormat": "4xx ratio"
        },
        {
          "expr": "((sum(rate(http_server_requests_seconds_count{job=\"sugang-v2-baseline\", uri=~\"/api/(baseline|optimistic)/enrollments\", status=~\"5..\"}[1m])) or vector(0)) / sum(rate(http_server_requests_seconds_count{job=\"sugang-v2-baseline\", uri=~\"/api/(baseline|optimistic)/enrollments\"}[1m])))",
          "legendFormat": "5xx ratio"
        }
