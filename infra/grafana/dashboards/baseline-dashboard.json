      "targets": [
        {
          "expr": "sum(rate(http_server_requests_seconds_count{job=\"sugang-v2-baseline\", uri=~\"/api/(baseline|optimistic)/enrollments\"}[1m]))",
          "legendFormat": "Spring request rate"
        },
        {
          "expr": "sum(rate(k6_http_reqs_total[1m]))",
          "legendFormat": "k6 request rate"
        }
      ],
      "title": "Request rate",
      "type": "timeseries"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "Prometheus"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "s"
        },
        "overrides": []
      },
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 8,
        "y": 0
      },
      "id": 2,
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom"
        },
        "tooltip": {
          "mode": "single",
          "sort": "none"
        }
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(http_server_requests_seconds_bucket{job=\"sugang-v2-baseline\", uri=~\"/api/(baseline|optimistic)/enrollments\"}[1m])) by (le))",
          "legendFormat": "Spring p95"
        },
        {
          "expr": "histogram_quantile(0.99, sum(rate(http_server_requests_seconds_bucket{job=\"sugang-v2-baseline\", uri=~\"/api/(baseline|optimistic)/enrollments\"}[1m])) by (le))",
          "legendFormat": "Spring p99"
        },
        {
          "expr": "max(k6_http_req_duration_p95{name=~\"http://app:8080/api/(baseline|optimistic)/enrollments\"}) / 1000",
          "legendFormat": "k6 p95"
        },
        {
          "expr": "max(k6_http_req_duration_p99{name=~\"http://app:8080/api/(baseline|optimistic)/enrollments\"}) / 1000",
          "legendFormat": "k6 p99"
        }
      ],
      "title": "P95/P99 latency",
      "type": "timeseries"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "Prometheus"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit"
        },
        "overrides": []
      },
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 16,
        "y": 0
      },
      "id": 3,
      "options": {
        "legend": {
          "displayMode": "table",
